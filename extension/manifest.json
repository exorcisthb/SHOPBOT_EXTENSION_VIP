{
  "manifest_version": 3,
  "name": "ShopBot AI - So Sánh Sản Phẩm",
  "version": "3.0.0",
  "description": "AI hỗ trợ so sánh & tư vấn mua sắm thông minh trên Shopee, Lazada, Tiki",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_icon": {
      "16": "icons/sb_v4_16.png",
      "48": "icons/sb_v4_48.png",
      "128": "icons/sb_v4_128.png"
    },
    "default_title": "ShopBot AI - Chụp để so sánh sản phẩm"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js", "widget.js"],
      "css": ["widget.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["widget.css", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/sb_v4_16.png",
    "48": "icons/sb_v4_48.png",
    "128": "icons/sb_v4_128.png"
  }
}